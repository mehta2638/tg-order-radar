# Application
APP_NAME=TG Order Radar
ENVIRONMENT=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
POSTGRES_DB=tg_order_radar
POSTGRES_USER=tg_order_radar
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_MAX_RETRIES=3
COLLECTOR_BATCH_LIMIT=500
COLLECTOR_BACKFILL_DAYS=7
COLLECTOR_BACKFILL_BUFFER_DAYS=1
COLLECTOR_LEASE_TTL_SECONDS=600
COLLECTOR_POLL_INTERVAL_SECONDS=60
DICTIONARY_CACHE_TTL_SECONDS=300
PROCESSING_FUZZY_ENABLED=true
CLASSIFICATION_MANUAL_REVIEW_MIN_CONFIDENCE=0.4
CLASSIFICATION_MANUAL_REVIEW_MAX_CONFIDENCE=0.6
CLASSIFICATION_ORDER_MIN_CONFIDENCE=0.6
ML_CLASSIFICATION_ENABLED=false
ML_MODEL_ARTIFACT_PATH=artifacts/ml/classifier.joblib
ML_MIN_CONFIDENCE=0.7
ML_MODEL_VERSION=
SEMANTIC_DEDUP_ENABLED=false
SEMANTIC_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_MODEL_VERSION=paraphrase-multilingual-MiniLM-L12-v2
SEMANTIC_EMBEDDING_DIMENSION=384
SEMANTIC_SIMILARITY_THRESHOLD=0.9
SEMANTIC_REVIEW_THRESHOLD=0.82
SEMANTIC_DEDUP_WINDOW_DAYS=7
SEMANTIC_BATCH_SIZE=32
SEMANTIC_DEVICE=
ORDER_MIN_RELEVANCE_SCORE=60
RELEVANCE_FRESHNESS_DAYS=7
RELEVANCE_WEIGHT_NEED=0.18
RELEVANCE_WEIGHT_TASK=0.16
RELEVANCE_WEIGHT_BUDGET=0.14
RELEVANCE_WEIGHT_DEADLINE=0.08
RELEVANCE_WEIGHT_CONTACT=0.10
RELEVANCE_WEIGHT_NICHE=0.14
RELEVANCE_WEIGHT_FRESHNESS=0.08
RELEVANCE_WEIGHT_P_CLIENT=0.12
RELEVANCE_WEIGHT_AD_PENALTY=0.10
RELEVANCE_WEIGHT_SPAM_PENALTY=0.10
API_KEY_ADMIN=dev-admin-key
API_KEY_OPERATOR=dev-operator-key
API_KEY_VIEWER=dev-viewer-key
BOT_TOKEN=
BOT_ALLOWED_USER_IDS=
BOT_RATE_LIMIT_SECONDS=0.2
BOT_SEND_MAX_RETRIES=3

# Telegram userbot collector (read-only public sources only)
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_DIR=.telegram-sessions
TG_SESSION_NAME=collector

# Never commit real API keys, bot tokens, or session files.
