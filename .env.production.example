# Copy to .env.production on the VPS (chmod 600). Never commit real values.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production ...

# --- Domains / TLS ---
DOMAIN_APP=app.example.com
DOMAIN_GRAFANA=grafana.example.com
ACME_EMAIL=ops@example.com
NEXT_PUBLIC_API_BASE_URL=https://app.example.com

# --- Application ---
APP_VERSION=0.1.0
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Database ---
POSTGRES_DB=tg_order_radar
POSTGRES_USER=tg_order_radar
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_MAX_RETRIES=3

# --- API keys (rotate in production) ---
API_KEY_ADMIN=change-me-admin-api-key
API_KEY_OPERATOR=change-me-operator-api-key
API_KEY_VIEWER=change-me-viewer-api-key

# --- Telegram notification bot ---
BOT_TOKEN=
BOT_ALLOWED_USER_IDS=
BOT_RATE_LIMIT_SECONDS=0.2
BOT_SEND_MAX_RETRIES=3

# --- Telegram userbot collector ---
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_DIR=/data/telegram-sessions
TG_SESSION_NAME=collector
# Used only to encrypt session archives during backup (openssl). Not a Telethon secret.
SESSION_ENC_KEY=change-me-session-backup-passphrase

# --- Observability ---
PROMETHEUS_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# --- Optional feature flags ---
ML_CLASSIFICATION_ENABLED=false
SEMANTIC_DEDUP_ENABLED=false
